            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "dependencies": {
        "@giscus/react": "3.1.0",
        "@happykit/flags": "3.3.0",
        "@tailwindcss/typography": "0.5.20",
        "daisyui": "5.5.23",
        "glob": "13.0.6",
        "gray-matter": "4.0.3",
        "just-unique": "4.2.0",
        "kutty": "0.6.0",
        "lite-youtube-embed": "0.3.4",
        "next": "16.2.9",
        "next-seo": "7.2.0",
        "next-themes": "0.4.6",
        "node-glob": "1.2.0",
        "prismjs": "1.30.0",
        "raw-loader": "4.0.2",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-markdown": "10.1.0",
        "remark-gfm": "4.0.1",
