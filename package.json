        "@types/react": "19.2.17",
        "autoprefixer": "10.5.0",
        "postcss": "8.5.15",
        "postcss-flexbugs-fixes": "5.0.2",
        "postcss-preset-env": "11.3.1",
        "sort-package-json": "3.7.1",
